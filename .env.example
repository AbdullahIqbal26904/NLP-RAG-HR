# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_CANDIDATE_INDEX=vend-candidates
PINECONE_JOB_INDEX=vend-jobs

# HuggingFace
HF_API_TOKEN=your_hf_token_here
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Groq (fallback LLM)
GROQ_API_KEY=your_groq_api_key_here

# App config
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_URDU=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# Urdu Pinecone indexes
PINECONE_URDU_CANDIDATE_INDEX=urdu-candidates
PINECONE_URDU_JOB_INDEX=urdu-jobs

# Urdu LLM (multilingual model for evaluation)
HF_URDU_MODEL_ID=Qwen/Qwen2.5-72B-Instruct
